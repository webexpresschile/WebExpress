---
export interface Props {
  business: {
    name: string;
    phone: string;
    email: string;
    address: string;
  };
}
const { business } = Astro.props;
---
<section id="contacto" class="py-20 md:py-28" style="background: linear-gradient(135deg, var(--primary), #16213e);">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">Contáctanos</h2>
    <div class="w-16 h-1 mx-auto mb-8 rounded" style="background-color: var(--secondary)" />
    <p class="text-gray-300 text-lg mb-10 max-w-lg mx-auto">
      ¿Preguntas? ¿Reservas? Estamos aquí para ayudarte.
    </p>

    <div class="grid md:grid-cols-3 gap-6 mb-10">
      <div class="bg-white/10 backdrop-blur rounded-xl p-6">
        <div class="text-3xl mb-3">📞</div>
        <a href={`tel:${business.phone}`} class="text-white font-semibold hover:underline">{business.phone}</a>
      </div>
      <div class="bg-white/10 backdrop-blur rounded-xl p-6">
        <div class="text-3xl mb-3">✉️</div>
        <a href={`mailto:${business.email}`} class="text-white font-semibold hover:underline">{business.email}</a>
      </div>
      <div class="bg-white/10 backdrop-blur rounded-xl p-6">
        <div class="text-3xl mb-3">📍</div>
        <p class="text-white font-semibold text-sm">{business.address}</p>
      </div>
    </div>

    <a href={`https://wa.me/${business.phone.replace(/[^0-9]/g, '')}`} target="_blank"
      class="inline-flex items-center gap-3 px-8 py-4 rounded-xl font-bold text-lg transition-all hover:scale-105 shadow-xl"
      style="background-color: var(--secondary); color: white;">
      <span>💬</span>
      Escríbenos por WhatsApp
    </a>
  </div>
</section>
