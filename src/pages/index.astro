  </style>

  <script>
    import { animate, createTimeline, stagger, set } from 'animejs';

    // ============ HERO ENTRANCE ============
    const heroTimeline = createTimeline({
      defaults: { easing: 'easeOutQuint' },
    });

    // Badge pill
    heroTimeline.add('#hero-badge', {
      opacity: [0, 1],
      translateY: [-16, 0],
      duration: 600,
    }, 0);

    // Hero title
    heroTimeline.add('#hero-title', {
      opacity: [0, 1],
      translateY: [30, 0],
      duration: 800,
    }, 200);

    // Hero subtitle
    heroTimeline.add('#hero-subtitle', {
      opacity: [0, 1],
      translateY: [20, 0],
      duration: 600,
    }, 600);

    // Hero buttons — staggered
    heroTimeline.add('#hero-buttons a', {
      opacity: [0, 1],
      translateY: [20, 0],
      duration: 500,
      delay: stagger(120),
    }, 900);

    // Terminal grid panes — staggered
    heroTimeline.add('#terminal-grid > div', {
      opacity: [0, 1],
      translateY: [40, 0],
      duration: 600,
      delay: stagger(100),
      easing: 'easeOutExpo',
    }, 1200);

    // Caption badges
    heroTimeline.add('#hero-captions span', {
      opacity: [0, 1],
      translateY: [10, 0],
      duration: 400,
      delay: stagger(80),
    }, 1800);

    // ============ SCROLL REVEAL ============
    const scrollObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        const animType = el.getAttribute('data-anim') || 'fade-up';
        
        const paramsMap = {
          'fade-up': { translateY: [40, 0], opacity: [0, 1], duration: 700, easing: 'easeOutQuart' },
          'fade-left': { translateX: [-40, 0], opacity: [0, 1], duration: 700, easing: 'easeOutQuart' },
          'fade-right': { translateX: [40, 0], opacity: [0, 1], duration: 700, easing: 'easeOutQuart' },
          'scale-in': { scale: [0.92, 1], opacity: [0, 1], duration: 700, easing: 'easeOutQuart' },
        };
        
        animate(el, paramsMap[animType] || paramsMap['fade-up']);
        scrollObserver.unobserve(el);
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('[data-anim]').forEach(el => scrollObserver.observe(el));

    // Staggered card groups
    document.querySelectorAll('[data-anim-stagger]').forEach(container => {
      const cards = container.querySelectorAll(':scope > *');
      const animType = container.getAttribute('data-anim-stagger') || 'fade-up';
      const delayBetween = parseInt(container.getAttribute('data-anim-delay') || '100');
      
      const cardObserver = new IntersectionObserver((entries) => {
        if (!entries[0].isIntersecting) return;
        
        const paramsMap = {
          'fade-up': { translateY: [40, 0], opacity: [0, 1], duration: 600, easing: 'easeOutQuart' },
          'scale-in': { scale: [0.92, 1], opacity: [0, 1], duration: 600, easing: 'easeOutQuart' },
        };
        
        animate(cards, {
          ...(paramsMap[animType] || paramsMap['fade-up']),
          delay: stagger(delayBetween),
        });
        
        cardObserver.unobserve(container);
      }, { threshold: 0.1 });
      cardObserver.observe(container);
    });

    // ============ NAV HAMBURGER ============
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobile-menu');
    if (hamburger && mobileMenu) {
      hamburger.addEventListener('click', () => {
        const isOpen = mobileMenu.style.display === 'block';
        if (isOpen) {
          animate('#mobile-menu > div', {
            opacity: [1, 0],
            translateY: [0, -10],
            duration: 200,
            easing: 'easeOutQuad',
            onfinish: () => { mobileMenu.style.display = 'none'; }
          });
        } else {
          mobileMenu.style.display = 'block';
          set('#mobile-menu > div', { opacity: 0, translateY: -10 });
          animate('#mobile-menu > div', {
            opacity: [0, 1],
            translateY: [-10, 0],
            duration: 300,
            easing: 'easeOutQuad',
          });
        }
      });
      document.querySelectorAll('.mobile-link').forEach(link => {
        link.addEventListener('click', () => {
          animate('#mobile-menu > div', {
            opacity: [1, 0],
            translateY: [0, -10],
            duration: 150,
            easing: 'easeOutQuad',
            onfinish: () => { mobileMenu.style.display = 'none'; }
          });
        });
      });
    }
  </script>
