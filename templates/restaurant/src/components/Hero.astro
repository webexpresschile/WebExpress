---
export interface Props {
  business: {
    name: string;
    shortDescription?: string;
    description: string;
    phone: string;
    hero_image_url?: string;
    hours: Record<string, string>;
  };
}
const { business } = Astro.props;

function isOpen(): boolean {
  const days = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
  const today = days[new Date().getDay()];
  const hours = business.hours[today];
  return hours && hours !== 'Cerrado';
}
---
<header class="relative min-h-[70vh] flex items-center" style="background: linear-gradient(135deg, var(--primary), #16213e);">
  <div class="absolute inset-0 bg-black/40 z-0" />
  <div class="relative z-10 max-w-5xl mx-auto px-4 w-full">
    {business.hero_image_url && (
      <img src={business.hero_image_url} alt={business.name} class="absolute inset-0 w-full h-full object-cover z-[-2]" />
    )}
    <div class="text-center md:text-left max-w-2xl">
      {business.logo_url && (
        <img src={business.logo_url} alt="Logo" class="h-16 md:h-20 mb-6 object-contain" />
      )}
      <h1 class="font-display text-4xl md:text-6xl lg:text-7xl text-white font-bold mb-4 leading-tight">
        {business.name}
      </h1>
      <p class="text-lg md:text-xl text-gray-200 mb-6 leading-relaxed">
        {business.shortDescription || business.description?.slice(0, 150) + '...'}
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="#menu"
          class="px-8 py-3 rounded-lg font-semibold transition-all hover:scale-105 text-white"
          style="background-color: var(--secondary)">
          Ver Menú
        </a>
        <a href={`https://wa.me/${business.phone.replace(/[^0-9]/g, '')}`} target="_blank"
          class="px-8 py-3 rounded-lg font-semibold border-2 border-white text-white hover:bg-white/10 transition-all">
          Pedir por WhatsApp
        </a>
      </div>
      <div class="mt-6 flex items-center gap-2 text-sm">
        <span class={`w-3 h-3 rounded-full ${isOpen() ? 'bg-green-400' : 'bg-red-400'}`} />
        <span class="text-gray-300">{isOpen() ? 'Abierto ahora' : 'Cerrado ahora'}</span>
      </div>
    </div>
  </div>
</header>
