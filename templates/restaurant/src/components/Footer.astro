---
export interface Props {
  business: {
    name: string;
    phone: string;
    email: string;
  };
}
const { business } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="py-10 border-t border-gray-200 bg-white">
  <div class="max-w-5xl mx-auto px-4">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <div>
        <p class="font-bold text-lg" style="color: var(--primary)">{business.name}</p>
        <p class="text-sm text-gray-500 mt-1">© {year} Todos los derechos reservados.</p>
      </div>
      <div class="flex gap-6 text-sm text-gray-500">
        <a href={`tel:${business.phone}`} class="hover:text-gray-700">{business.phone}</a>
        <a href={`mailto:${business.email}`} class="hover:text-gray-700">{business.email}</a>
      </div>
    </div>
    <div class="text-center mt-6 pt-6 border-t border-gray-100">
      <p class="text-xs text-gray-400">
        Creado con <a href="https://webexpress.cl" class="hover:underline" style="color: var(--secondary)">WebExpress</a>
      </p>
    </div>
  </div>
</footer>
