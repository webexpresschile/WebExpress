---
import BeamsBackground from '../components/BeamsBackground.jsx';
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>WebExpress — Presencia Digital Inteligente</title>
  <meta name="description" content="Sitio web profesional + Panel de edición + Chatbot con IA + Analytics. Tu negocio merece una presencia digital de otro nivel." />
  <meta property="og:title" content="WebExpress — Presencia Digital Inteligente" />
  <meta property="og:description" content="Sitio web profesional + Panel de edición + Chatbot con IA. Todo lo que tu negocio necesita para brillar online." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body style="background-color: #0f0f0f; color: #ffffff; font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;" class="antialiased">

  <!-- NAV -->
  <!-- nav-link: 14px 500, button-primary: 14px 500 8px 10px×18px 40px -->
  <nav style="background-color: rgba(15,15,15,0.85); border-bottom: 1px solid #222222;" class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl">
    <div class="max-w-[1200px] mx-auto px-6 h-16 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div style="background-color: #0007cd; border-radius: 8px;" class="w-8 h-8 flex items-center justify-center text-white text-xs font-medium">W</div>
        <span style="color: #ffffff; font-size: 14px; font-weight: 500; letter-spacing: 0;">WebExpress</span>
      </div>
      <div class="hidden lg:flex items-center gap-8" style="color: #888888; font-size: 14px; font-weight: 500; letter-spacing: 0;">
        <a href="#servicios" class="hover:text-white transition-colors">Servicios</a>
        <a href="#planes" class="hover:text-white transition-colors">Planes</a>
        <a href="#faq" class="hover:text-white transition-colors">FAQ</a>
      </div>
      <!-- button-primary: 14px/500, 8px radius, 10px × 18px padding, 40px height -->
      <a href="#cta" style="background-color: #0007cd; border-radius: 8px; font-size: 14px; font-weight: 500; line-height: 1; letter-spacing: 0; height: 40px; padding: 10px 18px;" class="text-white hover:opacity-90 transition-all inline-flex items-center justify-center hidden sm:inline-flex">
        Quiero mi sitio
      </a>
      <!-- Hamburger -->
      <button id="hamburger" style="background: none; border: none; padding: 8px;" class="lg:hidden flex flex-col gap-1.5 items-center justify-center" aria-label="Menu">
        <span class="ham-line" style="width: 20px; height: 2px; background: #ffffff; display: block;"></span>
        <span class="ham-line" style="width: 20px; height: 2px; background: #ffffff; display: block;"></span>
        <span class="ham-line" style="width: 20px; height: 2px; background: #ffffff; display: block;"></span>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" style="display: none; border-top: 1px solid #222222; background-color: #0f0f0f;" class="lg:hidden">
      <div class="px-6 py-6 flex flex-col gap-4">
        <a href="#servicios" class="mobile-link" style="color: #a8a8a8; font-size: 14px; font-weight: 500;">Servicios</a>
        <a href="#planes" class="mobile-link" style="color: #a8a8a8; font-size: 14px; font-weight: 500;">Planes</a>
        <a href="#faq" class="mobile-link" style="color: #a8a8a8; font-size: 14px; font-weight: 500;">FAQ</a>
        <a href="#cta" style="background-color: #0007cd; border-radius: 8px; font-size: 14px; font-weight: 500; line-height: 1; letter-spacing: 0; height: 40px; padding: 10px 18px;" class="inline-flex items-center justify-center text-white mt-2">Quiero mi sitio</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center pt-16 overflow-hidden" style="background-color: #0f0f0f;">
    <!-- spotlight-glow: radial center -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] pointer-events-none" style="background: radial-gradient(circle at center, rgba(0,7,205,0.25) 0%, rgba(0,7,205,0.08) 30%, transparent 60%);"></div>
    
    <div class="absolute inset-0 z-0 opacity-30">
      <BeamsBackground client:only="react" />
    </div>

    <div class="relative z-10 max-w-[1200px] mx-auto px-6 py-20 w-full">
      <div class="max-w-4xl mx-auto text-center">

        <!-- badge-pill: 11px 600 0.88px uppercase, #222 bg, pill radius, 4px×10px -->
        <div id="hero-badge" style="background-color: #222222; border-radius: 9999px; padding: 4px 10px; font-size: 11px; font-weight: 600; letter-spacing: 0.88px; line-height: 1.4; text-transform: uppercase;" class="inline-flex items-center gap-2 mb-10" style="color: #a8a8a8;">
          <span style="width: 6px; height: 6px; background: #33d17a; border-radius: 50%; display: inline-block;"></span>
          Hecho en Chile — disponible ahora
        </div>

        <!-- display-mega: clamp(40,7vw,72)px 500 1.05 -0.015em -->
  <!-- Responsive h1 sizes: mobile 36px, tablet 56px, desktop 72px via CSS rule below -->
        <h1 id="hero-title" style="font-weight: 500; line-height: 1.05; letter-spacing: -0.015em; color: #ffffff;" class="mb-6">
          Tu negocio merece una<br/>
          <span style="color: #0007cd;">presencia digital</span><br/>
          de otro nivel.
        </h1>

        <!-- body-md: 16px 400 1.5 -->
        <p id="hero-subtitle" style="font-size: 16px; font-weight: 400; line-height: 1.5; letter-spacing: 0;" class="max-w-2xl mx-auto mb-10" style="color: #a8a8a8;">
          Sitio web profesional + Panel para que edites tu mismo + Chatbot con IA que responde 24/7 + Analytics.
          <strong style="color: #ffffff; font-weight: 600;">Todo en uno. Sin complicaciones.</strong>
        </p>

        <!-- Buttons: button-primary + button-outline → 40px height, 8px radius, 14px/500 -->
        <div id="hero-buttons" class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <!-- button-primary: #0007cd bg, 8px, 10px×18px, 40px -->
          <a href="#planes" style="background-color: #0007cd; border-radius: 8px; font-size: 14px; font-weight: 500; line-height: 1; letter-spacing: 0; height: 40px; padding: 10px 18px;" class="inline-flex items-center justify-center text-white hover:opacity-90 transition-all">
            Ver Planes
          </a>
          <!-- button-outline: transparent, 1px #333 border, 8px -->
          <a href="#servicios" style="background-color: transparent; border: 1px solid #333333; border-radius: 8px; font-size: 14px; font-weight: 500; line-height: 1; letter-spacing: 0; height: 40px; padding: 10px 18px; color: #ffffff;" class="inline-flex items-center justify-center hover:opacity-80 transition-all">
            Que incluye
          </a>
        </div>

        <!-- terminal-mockup-grid: 16px radius container, #000 bg, 32px padding, 16px gap -->
        <!-- terminal-pane: #222 bg, 12px radius, 20px padding, 13px code -->
        <div id="terminal-grid" class="mt-20 max-w-3xl mx-auto">
          <div style="background-color: #000000; border: 1px solid #222222; border-radius: 16px;" class="grid grid-cols-1 sm:grid-cols-2 gap-4 p-4 sm:p-8">
            <div style="background-color: #222222; border-radius: 12px;" class="p-5 text-left">
              <div class="flex gap-1.5 mb-3">
                <span style="width: 8px; height: 8px; background: #ff4d4d; border-radius: 50%; display: inline-block;"></span>
                <span style="width: 8px; height: 8px; background: #ffd700; border-radius: 50%; display: inline-block;"></span>
                <span style="width: 8px; height: 8px; background: #33d17a; border-radius: 50%; display: inline-block;"></span>
              </div>
              <!-- typography.code: 13px 400 1.5 JetBrains Mono -->
              <p style="color: #a8a8a8; font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 400; line-height: 1.5; letter-spacing: 0;">
                <span style="color: #00d4ff;">$</span> WebExpress build<br/>
                <span style="color: #33d17a;">✓</span> Diseno a tu medida<br/>
                <span style="color: #a8a8a8;">→</span> <span style="color: #0007cd;">https://tusitio.cl</span>
              </p>
            </div>
            <div style="background-color: #222222; border-radius: 12px;" class="p-5 text-left">
              <div class="flex gap-1.5 mb-3">
                <span style="width: 8px; height: 8px; background: #ff4d4d; border-radius: 50%; display: inline-block;"></span>
                <span style="width: 8px; height: 8px; background: #ffd700; border-radius: 50%; display: inline-block;"></span>
                <span style="width: 8px; height: 8px; background: #33d17a; border-radius: 50%; display: inline-block;"></span>
              </div>
              <p style="color: #a8a8a8; font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 400; line-height: 1.5; letter-spacing: 0;">
                <span style="color: #00d4ff;">$</span> panel: tusitio.cl/admin<br/>
                <span style="color: #33d17a;">✓</span> Editas tu contenido<br/>
                <span style="color: #a8a8a8;">→</span> Cambios en vivo
              </p>
            </div>
            <div style="background-color: #222222; border-radius: 12px;" class="p-5 text-left">
              <div class="flex gap-1.5 mb-3">
                <span style="width: 8px; height: 8px; background: #ff4d4d; border-radius: 50%; display: inline-block;"></span>
                <span style="width: 8px; height: 8px; background: #ffd700; border-radius: 50%; display: inline-block;"></span>
                <span style="width: 8px; height: 8px; background: #33d17a; border-radius: 50%; display: inline-block;"></span>
              </div>
              <p style="color: #a8a8a8; font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 400; line-height: 1.5; letter-spacing: 0;">
                <span style="color: #00d4ff;">$</span> Chatbot activo 24/7<br/>
                <span style="color: #33d17a;">✓</span> WhatsApp integrado<br/>
                <span style="color: #a8a8a8;">→</span> <span style="color: #33d17a;">12 leads</span> esta semana
              </p>
            </div>
            <div style="background-color: #222222; border-radius: 12px;" class="p-5 text-left">
              <div class="flex gap-1.5 mb-3">
                <span style="width: 8px; height: 8px; background: #ff4d4d; border-radius: 50%; display: inline-block;"></span>
                <span style="width: 8px; height: 8px; background: #ffd700; border-radius: 50%; display: inline-block;"></span>
                <span style="width: 8px; height: 8px; background: #33d17a; border-radius: 50%; display: inline-block;"></span>
              </div>
              <p style="color: #a8a8a8; font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 400; line-height: 1.5; letter-spacing: 0;">
                <span style="color: #00d4ff;">$</span> Analytics<br/>
                <span style="color: #33d17a;">✓</span> 342 visitas este mes<br/>
                <span style="color: #a8a8a8;">→</span> 68% desde celular
              </p>
            </div>
          </div>
        </div>

        <!-- caption: 13px 400 1.4 -->
        <div id="hero-captions" class="mt-8 flex items-center justify-center gap-8" style="color: #666666; font-size: 13px; font-weight: 400; line-height: 1.4; letter-spacing: 0;">
          <span>Diseno profesional</span>
          <span style="width: 3px; height: 3px; background: #444444; border-radius: 50%; display: inline-block;"></span>
          <span>Sin tecnicismos</span>
          <span style="width: 3px; height: 3px; background: #444444; border-radius: 50%; display: inline-block;"></span>
          <span>100% personalizado</span>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEM — feature-card: #181818, 16px radius, 28px padding -->
  <section style="border-top: 1px solid #222222; background-color: #0f0f0f;">
    <div class="max-w-[1200px] mx-auto px-6" style="padding-top: 96px; padding-bottom: 96px;">
      <div class="text-center mb-20" data-anim="fade-up">
        <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.88px; line-height: 1.4; text-transform: uppercase; color: #888888;" class="mb-4">El problema</p>
        <h2 class="section-heading max-w-2xl mx-auto" style="font-weight: 500; line-height: 1.1; letter-spacing: -0.015em; color: #ffffff;">
          Cuantos clientes has perdido<br/>
          <span style="color: #666666;">por no tener presencia online?</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4" data-anim-stagger="fade-up" data-anim-delay="120">
        {[
          { num: '01', title: 'No te encuentran', desc: 'El 86% de las personas busca negocios en Google antes de comprar. Si no estas, no existes.' },
          { num: '02', title: 'Pareces poco profesional', desc: 'Sin sitio web, tu negocio se ve informal. Un cliente que investiga, elige al que tiene web.' },
          { num: '03', title: 'Pierdes ventas 24/7', desc: 'Mientras duermes, tus competidores estan captando clientes. Tu sitio nunca cierra.' },
        ].map(p => (
          <div data-anim="fade-up" style style="background-color: #181818; border: 1px solid #222222; border-radius: 16px; padding: 28px;">
            <span style="color: #0007cd; font-size: 36px; font-weight: 500; line-height: 1; letter-spacing: -0.015em;" class="block mb-4">{p.num}</span>
            <h3 style="font-size: 18px; font-weight: 600; line-height: 1.4; letter-spacing: 0; color: #ffffff;" class="mb-2">{p.title}</h3>
            <p style="font-size: 16px; font-weight: 400; line-height: 1.5; letter-spacing: 0; color: #a8a8a8;">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BIG STATEMENT -->
  <section style="border-top: 1px solid #222222; background-color: #0007cd;">
    <div class="max-w-[1200px] mx-auto px-6" style="padding-top: 80px; padding-bottom: 80px;">
      <p data-anim="scale-in" class="text-center mx-auto max-w-3xl" style="font-size: clamp(24px, 3vw, 36px); font-weight: 500; line-height: 1.1; letter-spacing: -0.015em; color: #ffffff;">
        No es solo una pagina web. Es un sistema que trabaja para ti 
        <em style="color: rgba(255,255,255,0.6); font-style: normal;">las 24 horas del dia.</em>
      </p>
    </div>
  </section>

  <!-- SERVICES — feature-card: #181818, 16px radius, 28px padding -->
  <section id="servicios" style="border-top: 1px solid #222222; background-color: #0f0f0f;">
    <div class="max-w-[1200px] mx-auto px-6" style="padding-top: 96px; padding-bottom: 96px;">
      <div class="text-center mb-20" data-anim="fade-up">
        <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.88px; line-height: 1.4; text-transform: uppercase; color: #888888;" class="mb-4">Todo incluido</p>
        <h2 class="section-heading max-w-xl mx-auto" style="font-weight: 500; line-height: 1.1; letter-spacing: -0.015em; color: #ffffff;">
          Tu ecosistema digital<br/>completo.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" data-anim-stagger="fade-up" data-anim-delay="100">
        {[
          { title: 'Sitio Web Profesional', desc: 'Disenado para tu rubro. Restaurante, clinica, servicios. Responsive, rapido y optimizado para Google.' },
          { title: 'Panel de Edicion', desc: 'Edita textos, fotos y horarios tu mismo. Sin saber de codigo. En 2 minutos tienes los cambios en vivo.' },
          { title: 'Chatbot WhatsApp con IA', desc: 'Responde clientes automaticamente 24/7. Entrenado con la informacion de tu negocio. Capta leads mientras trabajas.' },
          { title: 'Analytics Inteligente', desc: 'Sabes cuanta gente visita tu sitio, de donde vienen y que ven. Datos claros para tomar mejores decisiones.' },
          { title: 'Optimizado para Moviles', desc: 'El 70% de tus clientes te vera desde el telefono. Tu sitio se ve perfecto en cualquier pantalla.' },
          { title: 'Hosting + Dominio', desc: 'Nosotros nos encargamos de la parte tecnica. Tu sitio siempre online, rapido y seguro.' },
        ].map((s, i) => (
          <div data-anim="fade-up" style style="background-color: #181818; border: 1px solid #222222; border-radius: 16px; padding: 28px;">
            <!-- toolkit-icon: 40px square, #222 bg, 8px radius -->
            <div style="background-color: #222222; border-radius: 8px;" class="w-10 h-10 flex items-center justify-center mb-4" style="color: #0007cd; font-size: 16px; font-weight: 500;">
              {['W','E','C','A','M','H'][i]}
            </div>
            <h3 style="font-size: 18px; font-weight: 600; line-height: 1.4; letter-spacing: 0; color: #ffffff;" class="mb-2">{s.title}</h3>
            <p style="font-size: 16px; font-weight: 400; line-height: 1.5; letter-spacing: 0; color: #a8a8a8;">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="planes" style="border-top: 1px solid #222222; background-color: #0f0f0f;">
    <div class="max-w-[1200px] mx-auto px-6" style="padding-top: 96px; padding-bottom: 96px;">
      <div class="text-center mb-20" data-anim="fade-up">
        <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.88px; line-height: 1.4; text-transform: uppercase; color: #888888;" class="mb-4">Inversion unica</p>
        <h2 class="section-heading max-w-2xl mx-auto" style="font-weight: 500; line-height: 1.1; letter-spacing: -0.015em; color: #ffffff;">
          Precios claros,<br/>
          <span style="color: #0007cd;">sin sorpresas.</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto" data-anim-stagger="fade-up" data-anim-delay="150">
        <div style="background-color: #181818; border: 1px solid #222222; border-radius: 16px; padding: 28px;">
          <div class="flex items-center justify-between mb-6">
            <h3 style="font-size: 16px; font-weight: 600; line-height: 1.4; letter-spacing: 0; color: #ffffff;">Web Basica</h3>
            <!-- badge-pill: #222 bg, pill radius, 4px×10px -->
            <span style="background-color: #222222; color: #888888; border-radius: 9999px; padding: 4px 10px; font-size: 11px; font-weight: 600; letter-spacing: 0.88px; line-height: 1.4; text-transform: uppercase;">Para empezar</span>
          </div>
          <div class="mb-6">
            <span class="price-tag" style="font-weight: 500; line-height: 1; letter-spacing: -0.015em; color: #ffffff;">$160</span>
            <span style="color: #666666; font-size: 13px; font-weight: 400; line-height: 1.4;"> USD</span>
            <p style="font-size: 13px; font-weight: 400; line-height: 1.4; color: #666666; letter-spacing: 0;" class="mt-2">Pago unico. El sitio es tuyo.</p>
          </div>
          <ul class="space-y-3 mb-8">
            {[
              'Sitio web de 1 pagina',
              'Diseno profesional',
              'Boton WhatsApp integrado',
              'Formulario de contacto',
              'Hosting + dominio .cl por 1 ano',
              'Optimizado para celulares',
              'Ediciones via WhatsApp',
            ].map(f => (
              <li style="font-size: 16px; font-weight: 400; line-height: 1.5; letter-spacing: 0; color: #a8a8a8;" class="flex items-start gap-3">
                <span style="color: #33d17a; font-weight: 600;">✓</span>
                {f}
              </li>
            ))}
          </ul>
          <!-- button-secondary-dark: #222 bg, 8px radius, 40px, 10px×18px -->
          <a href="#cta" style="background-color: #222222; border: 1px solid #333333; border-radius: 8px; font-size: 14px; font-weight: 500; line-height: 1; letter-spacing: 0; height: 40px; padding: 10px 18px;" class="flex items-center justify-center w-full hover:opacity-80 transition-all" style="color: #ffffff;">
            Elegir Basica
          </a>
        </div>

        <div style="background-color: #0007cd; border-radius: 16px; padding: 28px;">
          <div class="flex items-center justify-between mb-6">
            <h3 style="font-size: 16px; font-weight: 600; line-height: 1.4; letter-spacing: 0; color: #ffffff;">Web Profesional</h3>
            <span style="background-color: rgba(255,255,255,0.15); color: #ffffff; border-radius: 9999px; padding: 4px 10px; font-size: 11px; font-weight: 600; letter-spacing: 0.88px; line-height: 1.4; text-transform: uppercase;">Mas elegido</span>
          </div>
          <div class="mb-6">
            <span class="price-tag" style="font-weight: 500; line-height: 1; letter-spacing: -0.015em; color: #ffffff;">$259</span>
            <span style="color: rgba(255,255,255,0.6); font-size: 13px; font-weight: 400; line-height: 1.4;"> USD</span>
            <p style="font-size: 13px; font-weight: 400; line-height: 1.4; color: rgba(255,255,255,0.6); letter-spacing: 0;" class="mt-2">Pago unico. Todo incluido.</p>
          </div>
          <ul class="space-y-3 mb-8">
            {[
              'Landing + hasta 5 secciones',
              'Panel de edicion',
              'Chatbot WhatsApp con IA 24/7',
              'Analytics de visitas',
              'Galeria de imagenes',
              'Google Maps integrado',
              'SEO basico',
              'Hosting + dominio .cl por 1 ano',
              'Capacitacion incluida',
            ].map(f => (
              <li style="font-size: 16px; font-weight: 400; line-height: 1.5; letter-spacing: 0; color: rgba(255,255,255,0.85);" class="flex items-start gap-3">
                <span style="color: #ffffff; font-weight: 600;">✓</span>
                {f}
              </li>
            ))}
          </ul>
          <!-- button-secondary-dark sobre azul -->
          <a href="#cta" style="background-color: #222222; border-radius: 8px; font-size: 14px; font-weight: 500; line-height: 1; letter-spacing: 0; height: 40px; padding: 10px 18px;" class="flex items-center justify-center w-full hover:opacity-80 transition-all" style="color: #ffffff;">
            Elegir Profesional
          </a>
        </div>
      </div>

      <p class="mt-10 text-center" data-anim="fade-up" style="font-size: 14px; font-weight: 400; line-height: 1.5; letter-spacing: 0; color: #666666;">
        No encuentras lo que buscas? <a href="#cta" style="color: #0007cd; font-weight: 500;" class="hover:underline">Conversemos</a> y armamos algo a tu medida.
      </p>
    </div>
  </section>

  <!-- HOW IT WORKS — feature-card: #181818, 16px radius, 28px padding -->
  <section style="border-top: 1px solid #222222; background-color: #0f0f0f;">
    <div class="max-w-[1200px] mx-auto px-6" style="padding-top: 96px; padding-bottom: 96px;">
      <div class="text-center mb-20" data-anim="fade-up">
        <p style="font-size: 11px; font-weight: 600; letter-spacing: 0.88px; line-height: 1.4; text-transform: uppercase; color: #888888;" class="mb-4">Como funciona</p>
        <h2 class="section-heading" style="font-weight: 500; line-height: 1.1; letter-spacing: -0.015em; color: #ffffff;">
          De cero a online,<br/>
