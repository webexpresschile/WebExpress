---
import BeamsBackground from '../components/BeamsBackground.jsx';
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>WebExpress — Presencia Digital Inteligente</title>
  <meta name="description" content="Sitio web profesional + Panel de edición + Chatbot con IA + Analytics. Tu negocio merece una presencia digital de otro nivel." />
  <meta property="og:title" content="WebExpress — Presencia Digital Inteligente" />
  <meta property="og:description" content="Sitio web profesional + Panel de edición + Chatbot con IA. Todo lo que tu negocio necesita para brillar online." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.2/anime.min.js"></script>
</head>
<body style="background-color: #0f0f0f; color: #ffffff;" class="font-sans antialiased">

  <!-- NAV -->
  <nav style="background-color: rgba(15,15,15,0.85); border-bottom: 1px solid #222222;" class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div style="background-color: #0007cd;" class="w-8 h-8 rounded-[8px] flex items-center justify-center text-white text-xs font-semibold">W</div>
        <span class="font-semibold text-base" style="color: #ffffff;">WebExpress</span>
      </div>
      <div class="hidden md:flex items-center gap-8 text-sm" style="color: #888888;">
        <a href="#servicios" class="hover:text-white transition-colors" style="font-weight: 500;">Servicios</a>
        <a href="#planes" class="hover:text-white transition-colors" style="font-weight: 500;">Planes</a>
        <a href="#faq" class="hover:text-white transition-colors" style="font-weight: 500;">FAQ</a>
      </div>
      <a href="#cta" style="background-color: #0007cd; border-radius: 8px;" class="px-5 py-2.5 text-white font-medium text-sm hover:opacity-90 transition-all">
        Quiero mi sitio
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center pt-16 overflow-hidden" style="background-color: #0f0f0f;">
    <!-- Spotlight glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] pointer-events-none" style="background: radial-gradient(circle at center, rgba(0,7,205,0.25) 0%, rgba(0,7,205,0.08) 30%, transparent 60%);"></div>
    
    <div class="absolute inset-0 z-0 opacity-30">
      <BeamsBackground client:only="react" />
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 py-20 w-full">
      <div class="max-w-3xl mx-auto text-center">
        <div style="background-color: rgba(0,7,205,0.12); border: 1px solid rgba(0,7,205,0.2); border-radius: 8px;" class="inline-flex items-center gap-2 px-4 py-1.5 text-xs mb-8" style="color: #a8a8a8;">
          <span style="width: 6px; height: 6px; background: #33d17a; border-radius: 50%; display: inline-block;"></span>
          Hecho en Chile — disponible ahora
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-semibold leading-[1.05] mb-6" style="color: #ffffff;">
          Tu negocio merece una<br/>
          <span style="color: #0007cd;">presencia digital</span><br/>
          de otro nivel.
        </h1>

        <p class="text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed" style="color: #a8a8a8;">
          Sitio web profesional + Panel para que edites tu mismo + Chatbot con IA que responde 24/7 + Analytics.
          <strong style="color: #ffffff;">Todo en uno. Sin complicaciones.</strong>
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#planes" style="background-color: #0007cd; border-radius: 8px;" class="px-8 py-3.5 text-white font-medium text-base hover:opacity-90 transition-all">
            Ver Planes
          </a>
          <a href="#servicios" style="border: 1px solid #333333; border-radius: 8px; background-color: #222222;" class="px-8 py-3.5 font-medium text-base hover:bg-[#2a2a2a] transition-all" style="color: #ffffff;">
            Que incluye
          </a>
        </div>

        <!-- Terminal mockup: 2×2 grid -->
        <div class="mt-20 max-w-3xl mx-auto">
          <div class="grid grid-cols-2 gap-px overflow-hidden rounded-[12px]" style="background-color: #000000; border: 1px solid #222222;">
            <div style="background-color: #181818;" class="p-5 text-left">
              <div class="flex gap-1.5 mb-3">
                <span style="width: 8px; height: 8px; background: #ff4d4d; border-radius: 50%; display: inline-block;"></span>
                <span style="width: 8px; height: 8px; background: #ffd700; border-radius: 50%; display: inline-block;"></span>
                <span style="width: 8px; height: 8px; background: #33d17a; border-radius: 50%; display: inline-block;"></span>
              </div>
              <p style="color: #888888; font-family: 'JetBrains Mono', monospace; font-size: 12px; line-height: 1.8;">
                <span style="color: #00d4ff;">$</span> npx webexpress create<br/>
                <span style="color: #33d17a;">✓</span> Sitio generado en 15s<br/>
                <span style="color: #a8a8a8;">→</span> <span style="color: #0007cd;">https://tusitio.cl</span>
              </p>
            </div>
            <div style="background-color: #181818;" class="p-5 text-left">
              <div class="flex gap-1.5 mb-3">
                <span style="width: 8px; height: 8px; background: #ff4d4d; border-radius: 50%; display: inline-block;"></span>
                <span style="width: 8px; height: 8px; background: #ffd700; border-radius: 50%; display: inline-block;"></span>
                <span style="width: 8px; height: 8px; background: #33d17a; border-radius: 50%; display: inline-block;"></span>
              </div>
              <p style="color: #888888; font-family: 'JetBrains Mono', monospace; font-size: 12px; line-height: 1.8;">
                <span style="color: #00d4ff;">$</span> panel: tusitio.cl/admin<br/>
                <span style="color: #33d17a;">✓</span> Editas tu contenido<br/>
                <span style="color: #a8a8a8;">→</span> Cambios en vivo
              </p>
            </div>
            <div style="background-color: #181818;" class="p-5 text-left">
              <div class="flex gap-1.5 mb-3">
                <span style="width: 8px; height: 8px; background: #ff4d4d; border-radius: 50%; display: inline-block;"></span>
                <span style="width: 8px; height: 8px; background: #ffd700; border-radius: 50%; display: inline-block;"></span>
                <span style="width: 8px; height: 8px; background: #33d17a; border-radius: 50%; display: inline-block;"></span>
              </div>
              <p style="color: #888888; font-family: 'JetBrains Mono', monospace; font-size: 12px; line-height: 1.8;">
                <span style="color: #00d4ff;">$</span> Chatbot activo 24/7<br/>
                <span style="color: #33d17a;">✓</span> WhatsApp integrado<br/>
                <span style="color: #a8a8a8;">→</span> <span style="color: #33d17a;">12 leads</span> esta semana
              </p>
            </div>
            <div style="background-color: #181818;" class="p-5 text-left">
              <div class="flex gap-1.5 mb-3">
                <span style="width: 8px; height: 8px; background: #ff4d4d; border-radius: 50%; display: inline-block;"></span>
                <span style="width: 8px; height: 8px; background: #ffd700; border-radius: 50%; display: inline-block;"></span>
                <span style="width: 8px; height: 8px; background: #33d17a; border-radius: 50%; display: inline-block;"></span>
              </div>
              <p style="color: #888888; font-family: 'JetBrains Mono', monospace; font-size: 12px; line-height: 1.8;">
                <span style="color: #00d4ff;">$</span> Analytics<br/>
                <span style="color: #33d17a;">✓</span> 342 visitas este mes<br/>
                <span style="color: #a8a8a8;">→</span> 68% desde celular
              </p>
            </div>
          </div>
        </div>

        <div class="mt-8 flex items-center justify-center gap-8 text-xs" style="color: #666666;">
          <span>15 min de configuracion</span>
          <span style="width: 3px; height: 3px; background: #444444; border-radius: 50%; display: inline-block;"></span>
          <span>Sin tecnicismos</span>
          <span style="width: 3px; height: 3px; background: #444444; border-radius: 50%; display: inline-block;"></span>
          <span>100% personalizado</span>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section style="border-top: 1px solid #222222; background-color: #0f0f0f;">
    <div class="max-w-6xl mx-auto px-6 py-24" style="padding-top: 96px; padding-bottom: 96px;">
      <div class="text-center mb-20 reveal">
        <p class="text-xs mb-4" style="color: #888888; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;">El problema</p>
        <h2 class="text-3xl md:text-5xl font-semibold leading-tight max-w-2xl mx-auto" style="color: #ffffff;">
          Cuantos clientes has perdido<br/>
          <span style="color: #666666;">por no tener presencia online?</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        {[
          { num: '01', title: 'No te encuentran', desc: 'El 86% de las personas busca negocios en Google antes de comprar. Si no estas, no existes.', icon: '🔍' },
          { num: '02', title: 'Pareces poco profesional', desc: 'Sin sitio web, tu negocio se ve informal. Un cliente que investiga, elige al que tiene web.', icon: '📱' },
          { num: '03', title: 'Pierdes ventas 24/7', desc: 'Mientras duermes, tus competidores estan captando clientes. Tu sitio nunca cierra.', icon: '⏰' },
        ].map(p => (
          <div class="reveal p-8 rounded-[8px]" style="background-color: #181818; border: 1px solid #222222;">
            <span style="color: #0007cd; font-size: 48px; font-weight: 700; line-height: 1;" class="block mb-4">{p.num}</span>
            <h3 class="text-lg font-semibold mb-3" style="color: #ffffff;">{p.title}</h3>
            <p class="text-sm leading-relaxed" style="color: #a8a8a8;">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BIG STATEMENT -->
  <section style="border-top: 1px solid #222222; background-color: #0007cd;">
    <div class="max-w-5xl mx-auto px-6 py-20" style="padding-top: 80px; padding-bottom: 80px;">
      <p class="reveal text-2xl md:text-4xl font-semibold leading-tight max-w-3xl text-center mx-auto" style="color: #ffffff;">
        No es solo una pagina web. Es un sistema que trabaja para ti 
        <em style="color: rgba(255,255,255,0.7); font-style: normal;">las 24 horas del dia.</em>
      </p>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="servicios" style="border-top: 1px solid #222222; background-color: #0f0f0f;">
    <div class="max-w-6xl mx-auto px-6 py-24" style="padding-top: 96px; padding-bottom: 96px;">
      <div class="text-center mb-20 reveal">
        <p class="text-xs mb-4" style="color: #888888; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;">Todo incluido</p>
        <h2 class="text-3xl md:text-5xl font-semibold max-w-xl mx-auto leading-tight" style="color: #ffffff;">
          Tu ecosistema digital<br/>completo.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        {[
          { title: 'Sitio Web Profesional', desc: 'Disenado para tu rubro. Restaurante, clinica, servicios. Responsive, rapido y optimizado para Google.', icon: 'W' },
          { title: 'Panel de Edicion', desc: 'Edita textos, fotos y horarios tu mismo. Sin saber de codigo. En 2 minutos tienes los cambios en vivo.', icon: 'E' },
          { title: 'Chatbot WhatsApp con IA', desc: 'Responde clientes automaticamente 24/7. Entrenado con la informacion de tu negocio. Capta leads mientras trabajas.', icon: 'C' },
          { title: 'Analytics Inteligente', desc: 'Sabes cuanta gente visita tu sitio, de donde vienen y que ven. Datos claros para tomar mejores decisiones.', icon: 'A' },
          { title: 'Optimizado para Moviles', desc: 'El 70% de tus clientes te vera desde el telefono. Tu sitio se ve perfecto en cualquier pantalla.', icon: 'M' },
          { title: 'Hosting + Dominio', desc: 'Nosotros nos encargamos de la parte tecnica. Tu sitio siempre online, rapido y seguro.', icon: 'H' },
        ].map((s, i) => (
          <div class="reveal p-8 rounded-[8px]" style="background-color: #181818; border: 1px solid #222222;">
            <div style="background-color: rgba(0,7,205,0.12); border: 1px solid rgba(0,7,205,0.2); border-radius: 8px;" class="w-10 h-10 flex items-center justify-center mb-4 text-sm font-semibold" style="color: #0007cd;">
              {s.icon}
            </div>
            <h3 class="text-base font-semibold mb-2" style="color: #ffffff;">{s.title}</h3>
            <p class="text-sm leading-relaxed" style="color: #a8a8a8;">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="planes" style="border-top: 1px solid #222222; background-color: #0f0f0f;">
    <div class="max-w-6xl mx-auto px-6 py-24" style="padding-top: 96px; padding-bottom: 96px;">
      <div class="text-center mb-20 reveal">
        <p class="text-xs mb-4" style="color: #888888; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;">Inversion unica</p>
        <h2 class="text-3xl md:text-5xl font-semibold max-w-2xl mx-auto leading-tight" style="color: #ffffff;">
          Precios claros,<br/>
          <span style="color: #0007cd;">sin sorpresas.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        <div class="p-8 rounded-[8px]" style="background-color: #181818; border: 1px solid #222222;">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-xl font-semibold" style="color: #ffffff;">Web Basica</h3>
            <span style="background-color: #222222; color: #888888; border-radius: 6px; padding: 4px 10px; font-size: 11px; font-weight: 500;">Para empezar</span>
          </div>
          <div class="mb-6">
            <span class="text-5xl font-semibold" style="color: #ffffff;">$160</span>
            <span style="color: #666666;" class="text-sm ml-1">USD</span>
            <p class="text-xs mt-2" style="color: #666666;">Pago unico. El sitio es tuyo.</p>
          </div>
          <ul class="space-y-3 mb-8">
            {[
              'Sitio web de 1 pagina',
              'Diseno profesional',
              'Boton WhatsApp integrado',
              'Formulario de contacto',
              'Hosting + dominio .cl por 1 ano',
              'Optimizado para celulares',
              'Ediciones via WhatsApp',
            ].map(f => (
              <li class="flex items-start gap-3 text-sm">
                <span style="color: #33d17a; font-weight: 700;">✓</span>
                <span style="color: #a8a8a8;">{f}</span>
              </li>
            ))}
          </ul>
          <a href="#cta" style="background-color: #222222; border: 1px solid #333333; border-radius: 8px; color: #ffffff;" class="block w-full py-3 text-center font-medium text-sm hover:bg-[#2a2a2a] transition-all">
            Elegir Basica
          </a>
        </div>

        <div class="p-8 rounded-[8px]" style="background-color: #0007cd;">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-xl font-semibold" style="color: #ffffff;">Web Profesional</h3>
            <span style="background-color: rgba(255,255,255,0.15); color: #ffffff; border-radius: 6px; padding: 4px 10px; font-size: 11px; font-weight: 500;">Mas elegido</span>
          </div>
          <div class="mb-6">
            <span class="text-5xl font-semibold" style="color: #ffffff;">$259</span>
            <span style="color: rgba(255,255,255,0.6);" class="text-sm ml-1">USD</span>
            <p class="text-xs mt-2" style="color: rgba(255,255,255,0.6);">Pago unico. Todo incluido.</p>
          </div>
          <ul class="space-y-3 mb-8">
            {[
              'Landing + hasta 5 secciones',
              'Panel de edicion',
              'Chatbot WhatsApp con IA 24/7',
              'Analytics de visitas',
              'Galeria de imagenes',
              'Google Maps integrado',
              'SEO basico',
              'Hosting + dominio .cl por 1 ano',
              'Capacitacion incluida',
            ].map(f => (
              <li class="flex items-start gap-3 text-sm">
                <span style="color: #ffffff; font-weight: 700;">✓</span>
                <span style="color: rgba(255,255,255,0.85);">{f}</span>
              </li>
            ))}
          </ul>
          <a href="#cta" style="background-color: #222222; border-radius: 8px; color: #ffffff;" class="block w-full py-3 text-center font-medium text-sm hover:bg-[#2a2a2a] transition-all">
            Elegir Profesional
          </a>
        </div>
      </div>

      <p class="text-sm mt-10 text-center reveal" style="color: #666666;">
        No encuentras lo que buscas? <a href="#cta" style="color: #0007cd; font-weight: 600;" class="hover:underline">Conversemos</a> y armamos algo a tu medida.
      </p>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section style="border-top: 1px solid #222222; background-color: #0f0f0f;">
    <div class="max-w-6xl mx-auto px-6 py-24" style="padding-top: 96px; padding-bottom: 96px;">
      <div class="text-center mb-20 reveal">
        <p class="text-xs mb-4" style="color: #888888; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;">Como funciona</p>
        <h2 class="text-3xl md:text-5xl font-semibold leading-tight" style="color: #ffffff;">
          De cero a online<br/>
          <span style="color: #0007cd;">en 15 minutos.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-4 gap-4">
        {[
          { step: '1', title: 'Conversamos', desc: 'Me cuentas de tu negocio, que haces, que necesitas. Sin tecnicismos.' },
          { step: '2', title: 'Creamos', desc: 'Con IA genero tu sitio con el contenido perfecto para tu negocio.' },
          { step: '3', title: 'Revisas', desc: 'Te paso el link. Ves como queda. Si algo no te gusta, lo ajustamos.' },
          { step: '4', title: 'Publicamos', desc: 'Tu sitio en linea. Tu chatbot activo. Tu negocio abierto 24/7.' },
        ].map((s, i) => (
          <div class="reveal p-8 rounded-[8px]" style="background-color: #181818; border: 1px solid #222222;">
            <span style="color: #0007cd; font-size: 36px; font-weight: 700; line-height: 1;" class="block mb-4">{s.step}</span>
            <h3 class="font-semibold text-base mb-2" style="color: #ffffff;">{s.title}</h3>
            <p class="text-sm leading-relaxed" style="color: #a8a8a8;">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BIG CTA -->
  <section style="border-top: 1px solid #222222; background-color: #000000;">
    <a href="#cta" class="block max-w-5xl mx-auto px-6 py-20 group text-center">
      <p class="reveal text-3xl md:text-5xl font-semibold leading-tight group-hover:opacity-80 transition-opacity" style="color: #ffffff;">
        Listo para <span style="color: #0007cd;">despegar</span>?
      </p>
    </a>
  </section>

  <!-- TESTIMONIALS -->
  <section style="border-top: 1px solid #222222; background-color: #0f0f0f;">
    <div class="max-w-6xl mx-auto px-6 py-24" style="padding-top: 96px; padding-bottom: 96px;">
      <div class="text-center mb-20 reveal">
        <p class="text-xs mb-4" style="color: #888888; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;">Resultados reales</p>
        <h2 class="text-3xl md:text-5xl font-semibold leading-tight" style="color: #ffffff;">
          Lo que dicen<br/>
          <span style="color: #0007cd;">nuestros clientes.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        {[
          { text: '"En dos dias tenia mi sitio funcionando. El chatbot ya me tomo 3 reservas mientras dormia."', name: 'Carlos M.', role: 'Restaurante' },
          { text: '"Pense que tener pagina web era caro y complicado. Me equivoque. Valio cada peso."', name: 'Maria F.', role: 'Clinica Dental' },
          { text: '"Lo mejor es que yo mismo puedo cambiar los precios y fotos. Ya no dependo de nadie."', name: 'Pedro G.', role: 'Servicios Tecnicos' },
        ].map(t => (
          <div class="reveal p-8 rounded-[8px]" style="background-color: #181818; border: 1px solid #222222;">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => <span style="color: #00d4ff; font-size: 16px;">★</span>)}
            </div>
            <p class="mb-6 text-sm leading-relaxed" style="color: #a8a8a8;">{t.text}</p>
            <div style="border-top: 1px solid #222222; padding-top: 16px;">
              <p class="text-sm font-medium" style="color: #ffffff;">{t.name}</p>
              <p class="text-xs" style="color: #888888;">{t.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" style="border-top: 1px solid #222222; background-color: #0f0f0f;">
    <div class="max-w-3xl mx-auto px-6 py-24" style="padding-top: 96px; padding-bottom: 96px;">
      <div class="text-center mb-16 reveal">
        <p class="text-xs mb-4" style="color: #888888; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;">FAQ</p>
        <h2 class="text-3xl md:text-5xl font-semibold leading-tight" style="color: #ffffff;">
          Preguntas<br/>
          <span style="color: #0007cd;">frecuentes.</span>
        </h2>
      </div>

      {[
        { q: 'Necesito saber de tecnologia?', a: 'Para nada. Yo me encargo de todo. Tu solo me cuentas de tu negocio y yo construyo el sitio. Si eliges el plan Profesional, tienes un panel para editar textos y fotos tu mismo, super intuitivo.' },
        { q: 'En cuanto tiempo tengo mi sitio?', a: 'La Web Basica la tienes en menos de 24 horas. La Profesional, con chatbot y panel, en 2-3 dias maximo.' },
        { q: 'Puedo cambiar cosas despues?', a: 'Si. En el plan Basico me escribes por WhatsApp y lo actualizo. En el Profesional tienes un panel donde editas tu mismo al instante.' },
        { q: 'El dominio es mio?', a: 'Si. El dominio .cl es tuyo. Si quieres cambiarte de proveedor despues, puedes llevartelo.' },
