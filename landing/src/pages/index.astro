---
---
<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>WebExpress — Presencia Digital Inteligente para tu Negocio</title>
  <meta name="description" content="Sitio web profesional + Panel de edición + Chatbot con IA + Analytics. Tu negocio merece una presencia digital de otro nivel." />
  <meta property="og:title" content="WebExpress — Presencia Digital Inteligente" />
  <meta property="og:description" content="Sitio web profesional + Panel de edición + Chatbot con IA. Todo lo que tu negocio necesita para brillar online." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,600;1,600&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.2/anime.min.js"></script>
</head>
<body class="font-sans bg-white text-black antialiased">

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-white border-b-2 border-black">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-black flex items-center justify-center text-white text-xs font-black">W</div>
        <span class="font-bold text-lg">WebExpress</span>
      </div>
      <div class="hidden md:flex items-center gap-8 text-sm font-medium">
        <a href="#servicios" class="hover:text-yellow-500 transition-colors">Servicios</a>
        <a href="#planes" class="hover:text-yellow-500 transition-colors">Planes</a>
        <a href="#faq" class="hover:text-yellow-500 transition-colors">FAQ</a>
      </div>
      <a href="#cta" class="px-5 py-2 bg-yellow-300 text-black font-bold text-sm border-2 border-black hover:bg-yellow-400 transition-all">
        Quiero mi sitio
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="min-h-screen flex items-center pt-14 border-b-2 border-black">
    <div class="max-w-6xl mx-auto px-6 py-20 w-full">
      <div class="max-w-4xl">
        <p class="hero-el font-mono text-xs tracking-[0.2em] uppercase mb-6 text-gray-400">Hecho en Chile 🇨🇱</p>

        <h1 class="hero-title text-5xl md:text-7xl lg:text-8xl font-black leading-[0.95] mb-8">
          Tu negocio merece<br/>
          una <em class="text-yellow-500 not-italic">presencia digital</em><br/>
          de otro nivel.
        </h1>

        <p class="hero-sub text-lg md:text-xl max-w-xl mb-10 leading-relaxed text-gray-600">
          Sitio web profesional + Panel para que edites tú mismo + Chatbot con IA que responde 24/7 + Analytics.
          <strong class="text-black">Todo en uno. Sin complicaciones.</strong>
        </p>

        <div class="flex flex-col sm:flex-row items-start gap-4">
          <a href="#planes" class="hero-cta px-8 py-4 bg-yellow-300 text-black font-bold text-lg border-2 border-black hover:bg-yellow-400 transition-all inline-flex items-center gap-2">
            <span>↓</span> Ver Planes
          </a>
          <a href="#servicios" class="hero-cta px-8 py-4 border-2 border-black font-bold text-lg hover:bg-gray-100 transition-all">
            ¿Qué incluye?
          </a>
        </div>

        <!-- STATS -->
        <div class="hero-sub mt-16 grid grid-cols-3 gap-12 max-w-lg">
          <div>
            <p class="stat-num text-5xl font-black" data-target="15">0</p>
            <p class="text-xs text-gray-500 mt-1 uppercase tracking-widest">Minutos en tenerlo</p>
          </div>
          <div>
            <p class="stat-num text-5xl font-black" data-target="100">0</p>
            <p class="text-xs text-gray-500 mt-1 uppercase tracking-widest">% Personalizado</p>
          </div>
          <div>
            <p class="text-5xl font-black">24/7</p>
            <p class="text-xs text-gray-500 mt-1 uppercase tracking-widest">Chatbot activo</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLEM / AGITATION -->
  <section class="border-b-2 border-black">
    <div class="max-w-6xl mx-auto px-6 py-24 md:py-32">
      <div class="reveal">
        <p class="font-mono text-xs tracking-[0.2em] uppercase mb-4 text-gray-400">El problema</p>
        <h2 class="text-3xl md:text-5xl font-black leading-tight mb-16 max-w-3xl">
          ¿Cuántos clientes has perdido<br/>
          <span class="text-gray-300">por no tener presencia online?</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-0 border-t-2 border-black">
        {[
          { num: '01', title: 'No te encuentran', desc: 'El 86% de las personas busca negocios en Google antes de comprar. Si no estás, no existes.' },
          { num: '02', title: 'Pareces poco profesional', desc: 'Sin sitio web, tu negocio se ve informal. Un cliente que investiga, elige al que tiene web.' },
          { num: '03', title: 'Pierdes ventas 24/7', desc: 'Mientras duermes, tus competidores están captando clientes. Tu sitio nunca cierra.' },
        ].map(p => (
          <div class="reveal border-r-2 border-black last:border-r-0 p-8 md:p-10">
            <span class="text-6xl md:text-7xl font-black text-yellow-300 block mb-6">{p.num}</span>
            <h3 class="text-xl font-bold mb-3">{p.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BIG STATEMENT -->
  <section class="border-b-2 border-black bg-yellow-300">
    <div class="max-w-6xl mx-auto px-6 py-20 md:py-28">
      <p class="reveal text-3xl md:text-4xl lg:text-5xl font-black leading-tight max-w-4xl">
        No es solo una página web. Es un sistema que trabaja para ti 
        <em class="text-black not-italic border-b-4 border-black">las 24 horas del día.</em>
      </p>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="servicios" class="border-b-2 border-black">
    <div class="max-w-6xl mx-auto px-6 py-24 md:py-32">
      <div class="text-left mb-16 reveal">
        <p class="font-mono text-xs tracking-[0.2em] uppercase mb-4 text-gray-400">Todo incluido</p>
        <h2 class="text-3xl md:text-5xl font-black max-w-xl leading-tight">
          Tu ecosistema digital<br/>completo.
        </h2>
      </div>

      <div class="grid md:grid-cols-2 border-t-2 border-black">
        {[
          { icon: '🎨', title: 'Sitio Web Profesional', desc: 'Diseñado para tu rubro. Restaurante, clínica, servicios… Adaptado a tu negocio. Responsive, rápido y optimizado para Google.' },
          { icon: '✏️', title: 'Panel de Edición', desc: 'Edita textos, fotos y horarios tú mismo. Sin saber de código. En 2 minutos tienes los cambios en vivo.' },
          { icon: '🤖', title: 'Chatbot WhatsApp con IA', desc: 'Responde clientes automáticamente 24/7. Entrenado con la información de tu negocio. Capta leads mientras trabajas o duermes.' },
          { icon: '📊', title: 'Analytics Inteligente', desc: 'Sabes cuánta gente visita tu sitio, de dónde vienen y qué ven. Datos claros para tomar mejores decisiones.' },
          { icon: '📱', title: 'Optimizado para Móviles', desc: 'El 70% de tus clientes te verá desde el teléfono. Tu sitio se ve perfecto en cualquier pantalla.' },
          { icon: '🔒', title: 'Hosting + Dominio', desc: 'Nosotros nos encargamos de la parte técnica. Tu sitio siempre online, rápido y seguro. Tú solo preocúpate de tu negocio.' },
        ].map((s, i) => (
          <div class="reveal p-8 md:p-10 border-b-2 border-black md:even:border-l-2 md:even:border-l-black md:[&:nth-last-child(-n+2)]:border-b-0">
            <span class="text-3xl block mb-4">{s.icon}</span>
            <h3 class="text-lg font-bold mb-2">{s.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="planes" class="border-b-2 border-black">
    <div class="max-w-6xl mx-auto px-6 py-24 md:py-32">
      <div class="text-left mb-16 reveal">
        <p class="font-mono text-xs tracking-[0.2em] uppercase mb-4 text-gray-400">Inversión única</p>
        <h2 class="text-3xl md:text-5xl font-black max-w-2xl leading-tight">
          Precios claros,<br/>
          <span class="text-yellow-500">sin sorpresas.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-0 max-w-4xl border-2 border-black">
        <!-- BASIC -->
        <div class="p-8 md:p-10 border-r-2 border-black md:border-r-2">
          <div class="flex items-center justify-between mb-8">
            <h3 class="text-2xl font-black">Web Básica</h3>
            <span class="px-3 py-1 text-xs font-bold bg-gray-100 border border-gray-300">Para empezar</span>
          </div>
          <div class="mb-8">
            <span class="text-6xl font-black">$160</span>
            <span class="text-gray-400 text-sm ml-1">USD</span>
            <p class="text-xs text-gray-500 mt-2">Pago único. El sitio es tuyo.</p>
          </div>
          <ul class="space-y-4 mb-10">
            {[
              'Sitio web de 1 página (Landing Page)',
              'Diseño profesional para tu rubro',
              'Botón WhatsApp integrado',
              'Formulario de contacto',
              'Hosting + dominio .cl por 1 año',
              'Optimizado para celulares',
              'Ediciones vía WhatsApp',
            ].map(f => (
              <li class="flex items-start gap-3 text-sm">
                <span class="text-yellow-500 font-black mt-0.5">✓</span>
                <span class="text-gray-700">{f}</span>
              </li>
            ))}
          </ul>
          <a href="#cta" class="block w-full py-3 text-center border-2 border-black font-bold hover:bg-gray-100 transition-all text-sm">
            Elegir Básica →
          </a>
        </div>

        <!-- PROFESSIONAL -->
        <div class="p-8 md:p-10 bg-yellow-300">
          <div class="flex items-center justify-between mb-8">
            <h3 class="text-2xl font-black">Web Profesional</h3>
            <span class="px-3 py-1 text-xs font-bold bg-white border border-black">Más elegido</span>
          </div>
          <div class="mb-8">
            <span class="text-6xl font-black">$259</span>
            <span class="text-gray-600 text-sm ml-1">USD</span>
            <p class="text-xs text-gray-600 mt-2">Pago único. Todo incluido.</p>
          </div>
          <ul class="space-y-4 mb-10">
            {[
              'Landing Page + hasta 5 secciones',
              'Panel de edición (editas tú mismo)',
              'Chatbot WhatsApp con IA 24/7',
              'Analytics (cuánta gente te visita)',
              'Galería de imágenes',
              'Integración Google Maps',
              'SEO básico (apareces en Google)',
              'Hosting + dominio .cl por 1 año',
              'Capacitación incluida',
            ].map(f => (
              <li class="flex items-start gap-3 text-sm">
                <span class="text-black font-black mt-0.5">✓</span>
                <span class="text-gray-800">{f}</span>
              </li>
            ))}
          </ul>
          <a href="#cta" class="block w-full py-3 text-center bg-black text-white font-bold hover:bg-gray-800 transition-all text-sm">
            Elegir Profesional →
          </a>
        </div>
      </div>

      <p class="text-gray-400 text-sm mt-8 reveal max-w-xl">
        ¿No encuentras lo que buscas? <a href="#cta" class="text-yellow-500 font-bold underline">Conversemos</a> y armamos algo a tu medida.
      </p>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="border-b-2 border-black">
    <div class="max-w-6xl mx-auto px-6 py-24 md:py-32">
      <div class="text-left mb-16 reveal">
        <p class="font-mono text-xs tracking-[0.2em] uppercase mb-4 text-gray-400">Cómo funciona</p>
        <h2 class="text-3xl md:text-5xl font-black leading-tight">
          De cero a online<br/>
          <span class="text-yellow-500">en 15 minutos.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-4 border-t-2 border-black">
        {[
          { step: '1', title: 'Conversamos', desc: 'Me cuentas de tu negocio, qué haces, qué necesitas. Sin tecnicismos.' },
          { step: '2', title: 'Creamos', desc: 'Con IA genero tu sitio con el contenido perfecto para tu negocio.' },
          { step: '3', title: 'Revisas', desc: 'Te paso el link. Ves cómo queda. Si algo no te gusta, lo ajustamos.' },
          { step: '4', title: 'Publicamos', desc: 'Tu sitio en línea. Tu chatbot activo. Tu negocio abierto 24/7.' },
        ].map((s, i) => (
          <div class="reveal p-8 md:p-10 border-r-2 border-black last:border-r-0">
            <span class="text-6xl font-black text-yellow-300 block mb-4">{s.step}</span>
            <h3 class="font-bold text-lg mb-2">{s.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BIG CTA TEXT -->
  <section class="border-b-2 border-black bg-black text-white">
    <a href="#cta" class="block max-w-6xl mx-auto px-6 py-20 md:py-28 group">
      <p class="reveal text-3xl md:text-5xl lg:text-6xl font-black leading-tight max-w-3xl group-hover:text-yellow-300 transition-colors">
        ¿Listo para<br/>
        <em class="text-yellow-300 not-italic group-hover:text-white transition-colors">despegar?</em>
      </p>
    </a>
  </section>

  <!-- TESTIMONIALS -->
  <section class="border-b-2 border-black">
    <div class="max-w-6xl mx-auto px-6 py-24 md:py-32">
      <div class="text-left mb-16 reveal">
        <p class="font-mono text-xs tracking-[0.2em] uppercase mb-4 text-gray-400">Resultados reales</p>
        <h2 class="text-3xl md:text-5xl font-black leading-tight">
          Lo que dicen<br/>
          <span class="text-yellow-500">nuestros clientes.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 border-t-2 border-black">
        {[
          { text: '"En dos días tenía mi sitio funcionando. El chatbot ya me tomó 3 reservas mientras dormía."', name: 'Carlos M.', role: 'Restaurante' },
          { text: '"Pensé que tener página web era caro y complicado. Me equivoqué. Valió cada peso."', name: 'María F.', role: 'Clínica Dental' },
          { text: '"Lo mejor es que yo mismo puedo cambiar los precios y fotos. Ya no dependo de nadie."', name: 'Pedro G.', role: 'Servicios Técnicos' },
        ].map((t, i) => (
          <div class="reveal p-8 md:p-10 border-r-2 border-black last:border-r-0">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => <span class="text-yellow-400 text-xl">★</span>)}
            </div>
            <p class="text-gray-600 mb-8 leading-relaxed text-sm">{t.text}</p>
            <div class="border-t-2 border-black pt-4">
              <p class="font-bold">{t.name}</p>
              <p class="text-gray-400 text-xs">{t.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="border-b-2 border-black">
    <div class="max-w-3xl mx-auto px-6 py-24 md:py-32">
      <div class="text-left mb-16 reveal">
        <p class="font-mono text-xs tracking-[0.2em] uppercase mb-4 text-gray-400">FAQ</p>
        <h2 class="text-3xl md:text-5xl font-black leading-tight">
          Preguntas<br/>
          <span class="text-yellow-500">frecuentes.</span>
        </h2>
      </div>

      {[
        { q: '¿Necesito saber de tecnología?', a: 'Para nada. Yo me encargo de todo. Tú solo me cuentas de tu negocio y yo construyo el sitio. Si eliges el plan Profesional, tienes un panel para editar textos y fotos tú mismo, súper intuitivo.' },
        { q: '¿En cuánto tiempo tengo mi sitio?', a: 'La Web Básica la tienes en menos de 24 horas. La Profesional, con chatbot y panel, en 2-3 días máximo.' },
        { q: '¿Puedo cambiar cosas después?', a: 'Sí. En el plan Básico me escribes por WhatsApp y lo actualizo. En el Profesional tienes un panel donde editas tú mismo al instante.' },
        { q: '¿El dominio es mío?', a: 'Sí. El dominio .cl es tuyo. Si quieres cambiarte de proveedor después, puedes llevártelo.' },
        { q: '¿Hay pagos mensuales?', a: 'No. Pagas una vez y el sitio es tuyo. El único costo recurrente opcional es si quieres mantener el chatbot con IA activo ($9/mes).' },
        { q: '¿Funciona para mi tipo de negocio?', a: 'Tengo plantillas para restaurantes, clínicas, servicios profesionales, tiendas… y si tu rubro no está, lo creamos desde cero para ti.' },
      ].map((item, i) => (
        <details class="reveal group border-b-2 border-black last:border-b-0">
          <summary class="flex items-center justify-between cursor-pointer list-none py-5 pr-4">
            <h3 class="font-bold text-lg">{item.q}</h3>
            <span class="text-2xl font-black group-open:rotate-45 transition-transform text-yellow-500">+</span>
          </summary>
          <p class="pb-5 text-gray-500 text-sm leading-relaxed max-w-xl">{item.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- CTA FINAL -->
  <section id="cta" class="border-b-2 border-black">
    <div class="max-w-6xl mx-auto px-6 py-24 md:py-32 text-center">
      <div class="reveal max-w-2xl mx-auto">
        <p class="font-mono text-xs tracking-[0.2em] uppercase mb-6 text-gray-400">¿Listo?</p>
        <h2 class="text-3xl md:text-5xl font-black mb-8 leading-tight">
          Háblame directo<br/>
          <span class="text-yellow-500">por WhatsApp.</span>
        </h2>
        <p class="text-gray-500 mb-10 max-w-md mx-auto">
          Sin compromiso. Te muestro ejemplos reales de negocios como el tuyo y te cuento cómo sería tu sitio.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="https://wa.me/569XXXXXXXX?text=Hola%20WebExpress!%20Quiero%20mi%20sitio%20web" target="_blank"
            class="px-10 py-4 bg-yellow-300 text-black font-bold text-lg border-2 border-black hover:bg-yellow-400 transition-all inline-flex items-center gap-3">
            💬 Hablar por WhatsApp
          </a>
          <a href="mailto:hola@webexpress.cl"
            class="px-10 py-4 border-2 border-black font-bold text-lg hover:bg-gray-100 transition-all">
            ✉️ hola@webexpress.cl
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-black text-white">
    <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex items-center gap-3 text-sm text-gray-400">
        <div class="w-6 h-6 bg-yellow-300 flex items-center justify-center text-black text-[10px] font-black">W</div>
        <span>WebExpress.cl — Hecho en Chile 🇨🇱</span>
      </div>
      <div class="flex gap-6 text-sm text-gray-400">
        <span>© {new Date().getFullYear()}</span>
        <a href="mailto:hola@webexpress.cl" class="hover:text-yellow-300 transition-colors">Contacto</a>
      </div>
    </div>
  </footer>

  <style>
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #fff; }
    ::-webkit-scrollbar-thumb { background: #000; }
  </style>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    document.addEventListener('DOMContentLoaded', () => {
      anime({
        targets: '.hero-title',
        opacity: [0, 1],
        translateY: [40, 0],
        easing: 'easeOutExpo',
        duration: 1000,
        delay: 200,
      });

      document.querySelectorAll('.hero-el, .hero-sub, .hero-cta').forEach((el, i) => {
        anime({
          targets: el,
          opacity: [0, 1],
          translateY: [15, 0],
          easing: 'easeOutExpo',
          duration: 600,
          delay: 600 + i * 150,
        });
      });

      document.querySelectorAll('.stat-num').forEach(el => {
        const target = parseInt(el.dataset.target);
        anime({
          targets: el,
          innerHTML: [0, target],
          easing: 'easeOutExpo',
          duration: 2000,
          delay: 1200,
          round: 1,
        });
      });
    });
  </script>
</body>
</html>
